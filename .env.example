# OpenAI-compatible multimodal chat endpoint.
REWARD_AS_AGENT_API_BASE=http://localhost:7000/v1
REWARD_AS_AGENT_API_KEY=dummy
REWARD_AS_AGENT_MODEL=/path/to/your/reward-model

# Reward service.
REWARD_AS_AGENT_HOST=0.0.0.0
REWARD_AS_AGENT_PORT=7024
REWARD_AS_AGENT_LOG_ROOT=./runs
REWARD_AS_AGENT_SAVE_INPUTS=true
REWARD_AS_AGENT_LLM_TIMEOUT=600
REWARD_AS_AGENT_MAX_RETRIES=10

# Reserved for future non-LLM motion-quality rewards. Currently disabled.
# REWARD_AS_AGENT_ENABLE_MOTION_QUALITY=false
# REWARD_AS_AGENT_MOTION_QUALITY_PATH=
